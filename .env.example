# Copy this file to .env and fill local values. Never commit .env.

# Flask
FLASK_APP=app.py
FLASK_CONFIG=development
PORT=3000
DEBUG=true
TESTING=false
WTF_CSRF_ENABLED=true

# Database
DB_HOST=localhost
DB_PORT=5432
DOCKER_DB_HOST=
DOCKER_DB_PORT=
DB_PUBLIC_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=
SQLALCHEMY_TRACK_MODIFICATIONS=false
TEST_DATABASE_URL=sqlite:////tmp/moneywise_test.db

# Application secrets
SECRET_KEY=
JWT_SECRET_KEY=
SECURITY_PASSWORD_SALT=

# JWT
JWT_TOKEN_LOCATION=cookies
JWT_COOKIE_SECURE=false
JWT_COOKIE_SAMESITE=Lax
JWT_COOKIE_CSRF_PROTECT=false
JWT_COOKIE_NAME=access_token_cookie
JWT_ACCESS_COOKIE_PATH=/
JWT_REFRESH_COOKIE_PATH=/auth/refresh
JWT_ACCESS_TOKEN_MINUTES=15

# Application email. The docker-compose.yml includes Mailpit for local email capture.
MAIL_SERVER=mailpit
MAIL_PORT=1025
MAIL_USE_TLS=false
MAIL_USE_SSL=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@moneywise.local
MAIL_CONTACT_RECIPIENT=contact@moneywise.local

# pgAdmin
PGADMIN_DEFAULT_EMAIL=
PGADMIN_DEFAULT_PASSWORD=

# Jenkins and Docker Hub
DOCKERHUB_IMAGE=
DOCKERHUB_CREDENTIALS_ID=dockerhub-credentials

# Jenkins notification. If blank, Jenkins falls back to MAIL_* values above.
NOTIFICATION_EMAIL=contact@moneywise.local
NOTIFICATION_FROM=noreply@moneywise.local
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USE_TLS=false
SMTP_USE_SSL=false
SMTP_USERNAME=
SMTP_PASSWORD=